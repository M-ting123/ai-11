{
  "name": "@edgeone/is-spa",
  "version": "0.0.3",
  "description": "Detect whether a frontend project is SPA, MPA, Hybrid, or SSG. Determine if Nginx/CDN fallback to index.html is needed.",
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js"
  },
  "bin": {
    "is-spa": "bin/cli.js"
  },
  "files": [
    "lib/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:dist": "node test/run-dist.js",
    "test:all": "node test/run.js && node test/run-dist.js",
    "prepublishOnly": "npm run test:all"
  },
  "keywords": [
    "spa",
    "mpa",
    "hybrid",
    "ssg",
    "detect",
    "single-page-application",
    "multi-page-application",
    "static-site-generation",
    "nginx",
    "fallback",
    "deploy",
    "vue",
    "react",
    "angular",
    "svelte",
    "nextjs",
    "nuxt",
    "sveltekit",
    "remix",
    "vite"
  ],
  "author": "corbinlin",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  }
}
