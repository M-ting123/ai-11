{
  "name": "@edgeone/framework-detect",
  "version": "0.0.2",
  "description": "A framework detection library for web projects",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "tsx test.ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "framework",
    "detection",
    "web",
    "next",
    "react",
    "vue",
    "angular",
    "svelte",
    "astro",
    "gatsby",
    "remix"
  ],
  "author": "zephyr",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.10.5",
    "rollup": "^3.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.20.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "acorn": "^8.15.0",
    "acorn-walk": "^8.3.4",
    "axios": "^1.11.0"
  }
}
